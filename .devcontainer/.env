POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mmoldb
POSTGRES_HOSTNAME=localhost
POSTGRES_PORT=5432

HTTP_CACHE_DIR=/etc/mmoldb-http-cache

# # Configure opentelemetry export to uptrace
OTEL_EXPORTER_OTLP_ENDPOINT="http://host.docker.internal:8362"  # grpc
# OTEL_EXPORTER_OTLP_HEADERS="uptrace-dsn=http://project1_secret@host.docker.internal:14318?http=14318"
# # Enable gzip compression.
# OTEL_EXPORTER_OTLP_COMPRESSION=gzip
# # Enable exponential histograms.
# OTEL_EXPORTER_OTLP_METRICS_DEFAULT_HISTOGRAM_AGGREGATION=BASE2_EXPONENTIAL_BUCKET_HISTOGRAM
# # Prefer delta temporality.
# OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE=DELTA
